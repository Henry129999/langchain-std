{
  "name": "langchain-agent-study",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Step-by-step LangChain JavaScript agent learning project.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
