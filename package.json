    "lesson:03": "tsx src/lessons/03-prompt-context.ts",
    "lesson:04": "tsx src/lessons/04-tool-design.ts",
    "lesson:05": "tsx src/lessons/05-first-agent.ts",
    "lesson:06": "tsx src/lessons/06-tool-engineering.ts",
    "lesson:07": "tsx src/lessons/07-structured-output.ts",
    "lesson:08": "tsx src/lessons/08-url-research-project.ts",
    "lesson:09": "tsx src/lessons/09-local-file-qa.ts",
    "lesson:10": "tsx src/lessons/10-rag-intro.ts",
    "lesson:11": "tsx src/lessons/11-streaming.ts",
    "lesson:12": "tsx src/lessons/12-langsmith-debugging-testing.ts",
