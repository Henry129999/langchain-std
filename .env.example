# Copy this file to .env and fill in the provider you want to use.

# OpenAI example from the LangChain quickstart.
OPENAI_API_KEY=
LANGCHAIN_MODEL=gpt-5.5

# Optional LangSmith tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# Other examples:
# GOOGLE_API_KEY=
# LANGCHAIN_MODEL=google-genai:gemini-2.5-flash-lite
#
# ANTHROPIC_API_KEY=
# LANGCHAIN_MODEL=claude-sonnet-4-6
#
# OPENROUTER_API_KEY=
# LANGCHAIN_MODEL=openrouter:anthropic/claude-sonnet-4-6
